{
  "manifest_version": 3,
  "name": "FschoolAI — File Importer",
  "version": "1.1.0",
  "description": "Import files from any website into FschoolAI for AI-powered tutoring. Works on any LMS, portal, or academic site.",

  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "downloads"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "externally_connectable": {
    "matches": [
      "http://localhost:5173/*",
      "https://fschoolai.com/*",
      "https://fschool-ai.vercel.app/*"
    ]
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "FschoolAI Importer"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
