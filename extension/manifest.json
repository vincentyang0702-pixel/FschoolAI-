{
  "manifest_version": 3,
  "name": "NeuroAgi",
  "version": "1.2.0",
  "description": "Sync your academic data to NeuroAgi — works on any university portal.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "NeuroAgi — Capture academic data"
  }
}
